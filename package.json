{
  "name": "allo-couscous",
  "version": "1.0.0",
  "main": "main.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "vercel-build": "npx expo export --platform web",
    "build:ios": "npx eas-cli@18.9.1 build --platform ios --profile production",
    "build:android:preview": "npx eas-cli@18.9.1 build --platform android --profile preview --clear-cache",
    "build:android": "npx eas-cli@18.9.1 build --platform android --profile production",
    "build:all": "npx eas-cli@18.9.1 build --platform all --profile production",
    "submit:ios": "npx eas-cli@18.9.1 submit --platform ios --profile production --latest",
    "submit:android": "npx eas-cli@18.9.1 submit --platform android --profile production --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
