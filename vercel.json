{
  "installCommand": "npm ci",
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/"
    },
    {
      "source": "/app",
      "destination": "/"
    },
    {
      "source": "/auth/reset-password",
      "destination": "/"
    }
  ]
}
